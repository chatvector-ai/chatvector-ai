# Base URL of the ChatVector backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# ChatVector API key for the frontend demo.
#
# ⚠  NEXT_PUBLIC_* variables are embedded in the browser bundle and visible to
#    anyone who inspects the page.  Only set this for local development or
#    demo deployments where you accept that the key is public.  For production,
#    proxy API calls through a Next.js Route Handler so the key stays server-side.
#
# Leave unset (or empty) when APP_ENV=development — the backend allows requests
# without authentication in development mode.
#
# NEXT_PUBLIC_CHATVECTOR_API_KEY=cv_live_yourprefixhere.yoursecrethere
